---
import { asset, type EnrichedShowcaseChannel, type ShowcaseVariant } from '../consts';

const { channels, activeId } = Astro.props as {
  channels: EnrichedShowcaseChannel[];
  activeId: string;
};
const thumb = (c: EnrichedShowcaseChannel) =>
  c.kind === 'clip'
    ? `demos/${c.asset}-poster.png`
    : `demos/${(c.variants.find((v: ShowcaseVariant) => v.featured) ?? c.variants[0]).src}`;
---

<div class="wall" role="group" aria-label="Demo channels">
  {
    channels.map((c: EnrichedShowcaseChannel) =>
      c.status === 'live' ? (
        <button class="mon" data-ch={c.id} aria-pressed={c.id === activeId ? 'true' : 'false'}>
          <span class="mon__screen">
            <img
              class="px"
              src={asset(thumb(c))}
              alt=""
              loading="lazy"
              width={c.w ?? 1600}
              height={c.h ?? 1440}
            />
            {c.duration && (
              <span class="mon__badge">
                <span aria-hidden="true">▶ </span>
                {c.duration}
              </span>
            )}
          </span>
          <span class="mon__label">
            CH {c.ch} · {c.label}
          </span>
        </button>
      ) : (
        <div class="mon mon--soon">
          <span class="mon__screen mon__screen--static">
            <span class="mon__badge mon__badge--soon">soon</span>
          </span>
          <span class="mon__label">
            CH {c.ch} · {c.label}
          </span>
        </div>
      )
    )
  }
</div>

<style>
  .wall {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
    align-content: start;
  }
  .mon {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.55rem;
    text-align: left;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: var(--shadow);
    transition:
      transform 0.15s ease,
      box-shadow 0.3s ease,
      border-color 0.2s ease;
  }
  button.mon {
    cursor: pointer;
  }
  button.mon:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--coral) 35%, var(--border));
  }
  .mon[aria-pressed='true'] {
    border-color: color-mix(in srgb, var(--coral) 60%, var(--border-strong));
    background: color-mix(in srgb, var(--coral) 12%, var(--surface));
    box-shadow:
      var(--shadow),
      0 0 0 1px color-mix(in srgb, var(--coral) 45%, transparent),
      0 0 22px var(--glow);
  }
  .mon__screen {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 6px;
    background: #0e0d0c;
  }
  .mon__screen img {
    display: block;
    width: 100%;
    height: auto;
  }
  .mon__badge {
    position: absolute;
    right: 6px;
    bottom: 6px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: #fff;
    background: rgba(0, 0, 0, 0.55);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .mon__label {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  .mon[aria-pressed='true'] .mon__label {
    color: var(--fg);
  }
  /* dim ONLY the dead-screen texture (mixed toward the page surface ≈ 0.55
     opacity, theme-aware) — an element-level opacity would also dim the
     label + "soon" badge text below WCAG 1.4.3 AA, and the badge lives
     inside the screen so it can't be exempted from a subtree opacity */
  .mon__screen--static {
    aspect-ratio: 1600 / 1440;
    background: repeating-linear-gradient(
      0deg,
      color-mix(in srgb, #0e0d0c 55%, var(--surface)) 0 2px,
      color-mix(in srgb, #211d1a 55%, var(--surface)) 2px 4px
    );
  }
  /* centered like a "stay tuned" test card, not a corner debug chip */
  .mon__badge--soon {
    right: 50%;
    bottom: 50%;
    transform: translate(50%, 50%);
    letter-spacing: 0.08em;
  }
  /* below the 2-col studio breakpoint the wall becomes a swipeable filmstrip */
  @media (max-width: 979px) {
    .wall {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: minmax(150px, 38%);
      overflow-x: auto;
      scroll-snap-type: x proximity;
      padding-bottom: 0.4rem;
    }
    .mon {
      scroll-snap-align: start;
    }
  }
</style>
