---
import { THEMES, asset } from '../consts';
const def = THEMES.find((t) => t.featured) ?? THEMES[0];
---

<section id="themes" class="themes">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{THEMES.length} built-in themes · more on the way</p>
      <h2>Reskin in one keystroke.</h2>
      <p class="lead">
        Press <code>t</code> in the app — or tap a chip below — to retint the whole office: lighting,
        furniture, even the city skyline shift together.
      </p>
    </div>

    <div class="themes__stage reveal" id="theme-stage" style={`--accent:${def.accent}`}>
      <figure class="terminal themes__preview crt">
        <div class="terminal__bar">
          <span class="terminal__dot terminal__dot--r"></span>
          <span class="terminal__dot terminal__dot--y"></span>
          <span class="terminal__dot terminal__dot--g"></span>
          <span class="terminal__title" id="theme-title">{def.name} · {def.blurb}</span>
        </div>
        <img
          id="theme-img"
          class="terminal__screen px"
          src={asset(`demos/theme_${def.id}.png`)}
          alt={`pixtuoid office in the ${def.name} theme`}
          width="1600"
          height="1440"
        />
        <span class="terminal__scan" aria-hidden="true"></span>
      </figure>

      <div class="themes__chips" role="group" aria-label="Theme">
        {
          THEMES.map((t) => (
            <button
              class:list={['themes__chip', { 'is-active': t.id === def.id }]}
              aria-pressed={t.id === def.id ? 'true' : 'false'}
              data-id={t.id}
              data-src={asset(`demos/theme_${t.id}.png`)}
              data-name={t.name}
              data-blurb={t.blurb}
              data-accent={t.accent}
              data-accent2={t.accent2}
              style={`--chip:${t.accent}`}
            >
              <span class="themes__swatch" />
              {t.name}
            </button>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const stage = document.getElementById('theme-stage');
    const img = document.getElementById('theme-img');
    const title = document.getElementById('theme-title');
    const chips = document.querySelectorAll('.themes__chip');
    if (!stage || !img) return;
    function pick(chip) {
      img.src = chip.dataset.src;
      img.alt = 'pixtuoid office in the ' + chip.dataset.name + ' theme';
      if (title) title.textContent = chip.dataset.name + ' · ' + chip.dataset.blurb;
      stage.style.setProperty('--accent', chip.dataset.accent);
      // Retint the page's DECORATIVE hues (gradient/glow/cursor/dividers) to
      // preview this theme — like hitting `t` in the app. Deliberately NOT
      // --coral-deep: that's the AA text color for links/eyebrows/prose, and
      // setting it to a raw chip accent drops body text below WCAG 1.4.3 on cream.
      const root = document.documentElement;
      root.style.setProperty('--coral', chip.dataset.accent);
      root.style.setProperty('--amber', chip.dataset.accent2 || chip.dataset.accent);
      const preview = stage.querySelector('.themes__preview');
      if (preview) {
        preview.classList.remove('retint-pulse');
        void preview.offsetWidth;
        preview.classList.add('retint-pulse');
      }
      chips.forEach(function (c) {
        const on = c === chip;
        c.classList.toggle('is-active', on);
        c.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    }
    const prefetched = {};
    function prefetch(src) {
      if (src && !prefetched[src]) {
        prefetched[src] = new Image();
        prefetched[src].src = src;
      }
    }
    chips.forEach(function (c) {
      // warm the theme PNG on hover so the click swaps an already-cached image
      c.addEventListener('pointerenter', function () {
        prefetch(c.dataset.src);
      });
      c.addEventListener('click', function () {
        pick(c);
      });
    });
    // A non-gallery theme change (Nav toggle / Escape / dracula egg all dispatch
    // pix:theme) clears the retint, so no chip should still read as active/pressed.
    document.addEventListener('pix:theme', function () {
      chips.forEach(function (c) {
        c.classList.remove('is-active');
        c.setAttribute('aria-pressed', 'false');
      });
    });
  })();
</script>

<style>
  .themes__stage {
    --accent: var(--coral);
    display: grid;
    gap: 1.4rem;
  }
  .themes__preview {
    border-color: color-mix(in srgb, var(--accent) 50%, var(--border-strong));
    box-shadow:
      var(--shadow-lg),
      0 0 0 1px color-mix(in srgb, var(--accent) 22%, transparent),
      0 30px 80px color-mix(in srgb, var(--accent) 22%, transparent);
    transition:
      box-shadow 0.45s ease,
      border-color 0.45s ease;
  }
  .themes__preview .terminal__screen {
    width: 100%;
    height: auto;
  }
  .themes__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .themes__chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.84rem;
    padding: 0.5rem 0.95rem;
    border-radius: 999px;
    cursor: pointer;
    color: var(--fg-muted);
    background: var(--surface);
    border: 1px solid var(--border);
    transition:
      color 0.2s ease,
      background-color 0.2s ease,
      border-color 0.2s ease,
      transform 0.15s ease;
  }
  .themes__chip:hover {
    color: var(--fg);
    transform: translateY(-1px);
  }
  .themes__swatch {
    width: 12px;
    height: 12px;
    border-radius: 3px;
    background: var(--chip);
    /* a perceivable edge so the swatch reads even when its fill is below the
       WCAG 1.4.11 3:1 non-text contrast against the chip surface */
    border: 1px solid var(--border-strong);
    image-rendering: pixelated;
  }
  .themes__chip.is-active {
    color: var(--fg);
    border-color: var(--chip);
    background: color-mix(in srgb, var(--chip) 15%, var(--surface));
  }
</style>
