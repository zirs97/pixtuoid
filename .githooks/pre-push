#!/usr/bin/env bash
# Pre-push hook: runs the full preflight (mirrors CI) before pushing.
# Pre-commit only checks formatting; this is the gate for everything else.
#
# Set up once per clone with:
#   git config core.hooksPath .githooks
#
# Bypass with `--no-verify` or `SKIP_PREFLIGHT=1`.
set -euo pipefail
exec "$(git rev-parse --show-toplevel)/scripts/preflight.sh"
